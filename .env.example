# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Set to "true" only for local debugging without Auth (not for production)
AUTH_DISABLED=false

# Optional: show "Create account" on /login (requires Supabase email confirmations configured)
NEXT_PUBLIC_ALLOW_SIGNUP=false

# SMS Gateway (optional — for payment/salary confirmation SMS)
# Supported gateways: bulksmsbd, sslwireless, greenweb, none
# Set to "none" or leave empty to disable SMS
SMS_GATEWAY=none
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=SchoolERP
